# Copy to .env and adjust as needed:  cp .env.example .env
# docker compose reads .env automatically. Every value below has a built-in
# default, so an empty .env works out of the box.

# ---- Database ----
POSTGRES_DB=teu_armario_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DB_PORT=5432

# ---- Backend ----
BACKEND_PORT=8080
# Hibernate schema strategy: 'update' keeps data across restarts,
# 'create-drop' rebuilds the schema every boot.
DDL_AUTO=update
# Allowed origins for REST CORS and the WebSocket handshake (comma-separated).
# The default patterns already cover any localhost port.
CORS_ALLOWED_ORIGINS=http://localhost:*,http://127.0.0.1:*

# ---- Web (back-office) ----
WEB_PORT=8081
# Leave WEB_VITE_API_BASE empty so API calls are same-origin (proxied by nginx).
WEB_VITE_API_BASE=
# IMPORTANT: this is baked into the bundle at build time and must match the URL
# the browser uses to reach the web app. If you change WEB_PORT, change this too.
# Re-run `docker compose build web` after changing it.
WEB_VITE_WS_URL=ws://localhost:8081/ws-simulator

# ---- Simulator ----
SIM_PORT=8082
SIM_VITE_API_BASE=
SIM_VITE_WS_URL=ws://localhost:8082/ws-simulator
